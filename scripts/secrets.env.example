# Supabase Edge Function secrets — template.
#
# Copy this file to `scripts/secrets.env` (gitignored) and fill in real
# values. Then run `scripts/set_secrets.ps1` to push them to the
# Supabase project. Never commit the real `secrets.env`.

# Resend transactional email API key (used by request-activation-code +
# request-product-license). Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# BulkSMSGateway credentials (used by send-password-reset-otp)
BULKSMS_USER=
BULKSMS_PASSWORD=
BULKSMS_SENDER=TBSTEC
BULKSMS_TEMPLATE_ID=

# Razorpay credentials (used by create-razorpay-order + get-razorpay-payment).
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# AES-256 key for encrypting the device-code JSON in the request-device-code
# email. Generate with:  openssl rand -base64 32
# The SAME value must also be pasted into lib/config/device_code_key.dart.
DEVICE_CODE_ENC_KEY=

# Note: SUPABASE_DB_URL, SUPABASE_URL, and SUPABASE_SERVICE_ROLE_KEY are
# auto-injected by the Edge Function runtime — do NOT set them here.
